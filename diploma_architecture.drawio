        <mxCell id="e_an_func" value="SQL: adm_create_rule / dry_run / trigger / enable …" style="endArrow=classic;html=1;fontSize=10;fontStyle=1;strokeColor=#9673a6;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="act_analyst" target="pg_funcs">
