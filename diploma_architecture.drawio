          <mxGeometry x="710" y="820" width="100" height="22" as="geometry" />
        </mxCell>

        <!-- ACTORS -->
        <mxCell id="act_analyst" value="Аналитик&#10;(DBeaver)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="act_bi" value="BI-аналитик&#10;(браузер)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1240" y="80" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- LEFT: SOURCES -->
        <mxCell id="src_pg" value="Postgres movies-db&#10;content.film_work, auth.users&#10;(+ миграция nullable-колонок&#10;в auth.users для сегментации)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;boundedLbl=1;backgroundOutline=1;size=15;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="src_kafka" value="Kafka&#10;(события пользователей)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- CENTER: STARROCKS -->
        <mxCell id="sr_box" value="StarRocks (ugc_analytics)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#444444;verticalAlign=top;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="170" width="380" height="320" as="geometry" />
        </mxCell>

        <mxCell id="sr_user_events" value="user_events&#10;(наполняется Routine Load из Kafka)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="210" width="340" height="55" as="geometry" />
        </mxCell>

        <mxCell id="sr_dims" value="dim_films, dim_users, dim_genres&#10;(JDBC Catalog + SUBMIT TASK SCHEDULE EVERY 1 HOUR&#10;— синхронизация внутри StarRocks, без внешнего ETL)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="285" width="340" height="70" as="geometry" />
        </mxCell>

