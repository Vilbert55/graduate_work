        </mxCell>

        <mxCell id="sr_role_note" value="Движок ходит под ролью alert_reader (только SELECT)" style="text;html=1;align=center;fontSize=9;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="400" y="455" width="340" height="20" as="geometry" />
        </mxCell>

        <!-- RIGHT: ENGINE -->
        <mxCell id="eng" value="alerting-engine (Python)&#10;&#10;• Планировщик (APScheduler) — по cron каждого правила&#10;• Исполнитель SQL в StarRocks (тайм-аут, потолок выборки)&#10;• Проверка лимита уведомлений&#10;• Создание задачи в notifications (одна транзакция,&#10;  идемпотентный ключ alerting:&#123;rule_id&#125;:&#123;run_id&#125;)&#10;• Восстановление прерванных запусков на старте&#10;• Счётчики и метрики — структурированными логами в ELK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;fontSize=10;align=left;spacingLeft=12;spacingTop=8;verticalAlign=top;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="880" y="170" width="380" height="240" as="geometry" />
        </mxCell>

        <!-- NOTIFICATIONS (external) -->
        <mxCell id="ext_notif" value="notifications-service&#10;adm_create_task(...) / adm_upsert_template(...)&#10;(существует, не модифицируется)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="450" width="380" height="70" as="geometry" />
        </mxCell>

        <!-- POSTGRES: ALERTING SCHEMA -->
        <mxCell id="pg_box" value="Postgres movies-db — schema alerting (новая)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#444444;verticalAlign=top;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="1320" height="230" as="geometry" />
        </mxCell>

        <mxCell id="pg_funcs" value="SQL-функции adm_*&#10;(SECURITY DEFINER, GRANT EXECUTE на alerting_admin)&#10;&#10;create_rule / update_rule&#10;enable_rule / disable_rule&#10;delete_rule (мягкое)&#10;dry_run_rule / trigger_rule" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="600" width="380" height="170" as="geometry" />
        </mxCell>

        <mxCell id="pg_views" value="Представления для аудита&#10;&#10;v_rules — правила со статусом и расписанием&#10;v_runs — история срабатываний&#10;v_dispatch — история отправок&#10;(только SELECT для alerting_admin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="470" y="600" width="380" height="170" as="geometry" />
        </mxCell>

        <mxCell id="pg_tables" value="Таблицы (доступ только у движка)&#10;&#10;t_rules — правила&#10;t_runs — история запусков&#10;t_dispatch_history — отправки (партиции по неделям,&#10;для лимита уведомлений и аудита)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;align=left;spacingLeft=20;spacingTop=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="880" y="600" width="460" height="170" as="geometry" />
        </mxCell>

        <!-- SUPERSET -->
        <mxCell id="superset" value="Apache Superset&#10;(дашборды поверх mv_*,&#10;MySQL-коннектор к StarRocks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1180" y="240" width="180" height="70" as="geometry" />
