                    <mxGeometry x="40" y="560" width="1320" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="pg_funcs" value="SQL-функции adm_*&#xa;(SECURITY DEFINER, GRANT EXECUTE на alerting_admin)&#xa;&#xa;create_rule / update_rule&#xa;enable_rule / disable_rule&#xa;delete_rule&#xa;dry_run_rule / trigger_rule" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;" parent="1" vertex="1">
