PROJECT_NAME="Movie theater"
PROJECT_DESCRIPTION="The best movie theater for everyone"

# Настройки Django
DEBUG=True
SECRET_KEY=folaskdfjYHLHhjlhljkh7678yhlkjgkfkfgkjo
ALLOWED_HOSTS=127.0.0.1,localhost

# Универсальные настройки (работают везде)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=movies
POSTGRES_DB=movies

# По умолчанию для локальной разработки (runserver)
SQL_HOST=localhost
DB_PORT=5438
EXTERNAL_DB_PORT=5438

SQL_OPTIONS=-c search_path=public,content
DATABASE_TYPE=postgres

# Elasticsearch
ELASTICSEARCH_HOST=movies-elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEMA=http://

# ETL
ETL_CRON_SCHEDULE=*/1 * * * *    # Расписание (cron)
ETL_BATCH_SIZE=200               # Размер пакета
LOG_LEVEL=INFO                   # Уровень логирования

# Redis для FastAPI
REDIS_HOST=movies-redis
REDIS_PORT=6379

# Сервис авторизации

## Настройки основные
AUTH_SERVER_HOST=0.0.0.0
AUTH_SERVER_PORT=8002
AUTH_JWT_SECRET_KEY=your-strong-secret-key
AUTH_JWT_ALGORITHM=HS256
AUTH_SUPERUSER_LOGIN=admin
AUTH_SUPERUSER_PASSWORD=strong-password
AUTH_DEBUG=true

## Ограничения запросов
AUTH_LOGIN_RATE_LIMIT_REQUESTS=40
AUTH_LOGIN_RATE_LIMIT_PERIOD=60
AUTH_REGISTER_RATE_LIMIT_REQUESTS=40
AUTH_REGISTER_RATE_LIMIT_PERIOD=60

# Настройки OAuth
AUTH_YANDEX_CLIENT_ID=client_id_123
AUTH_YANDEX_CLIENT_SECRET=client_secret_123

# Сервис пользовательского контента (закладки, оценки, рецензии)
COMMUNITY_SERVER_HOST=0.0.0.0
COMMUNITY_SERVER_PORT=8004
COMMUNITY_SERVER_RELOAD=false
COMMUNITY_DEBUG=false
COMMUNITY_JAEGER_ENDPOINT=movies-jaeger:4317

# Glithtip (self-hosted, доступен на http://localhost:9000)
# SENTRY_SECRET_KEY — случайная строка ≥50 символов, можно сгенерировать: python -c "import secrets; print(secrets.token_hex(50))"
SENTRY_SECRET_KEY=sentry_secret_key_change_me_in_production
SENTRY_ADMIN_EMAIL=admin@example.com
SENTRY_ADMIN_PASSWORD=admin_password # минимум 8 символов

# Sentry DSN для каждого сервиса
# Оставить пустым, чтобы отключить Sentry в сервисе.
# После запуска стека создать проекты в веб-интерфейсе glitchtip:
#   auth, films-search, community-content, activity-tracker
# Важно: в DSN использовать sentry-api:8000 (внутренний порт контейнера, НЕ проброшенный 9000)
AUTH_SENTRY_DSN=http://<ключ>@sentry-api:8000/<id>
FILMS_SEARCH_SENTRY_DSN=http://<ключ>@sentry-api:8000/<id>
COMMUNITY_SENTRY_DSN=http://<ключ>@sentry-api:8000/<id>
UGC_SENTRY_DSN=http://<ключ>@sentry-api:8000/<id>

# UGC API
UGC_KAFKA_HOST=movies-kafka
UGC_KAFKA_PORT=9092
UGC_KAFKA_TOPIC_CLICKS=clicks
UGC_KAFKA_TOPIC_VIEWS=views
UGC_KAFKA_TOPIC_CUSTOM=custom_events
UGC_DEBUG=false

# Сервис нотификаций

## RabbitMQ
NOTIFICATIONS_RABBIT_HOST=movies-rabbitmq
NOTIFICATIONS_RABBIT_PORT=5672
NOTIFICATIONS_RABBIT_USER=guest
NOTIFICATIONS_RABBIT_PASSWORD=guest
NOTIFICATIONS_RABBIT_VHOST=/

## SMTP (Mailpit для разработки)
NOTIFICATIONS_SMTP_HOST=movies-mailpit
NOTIFICATIONS_SMTP_PORT=1025
NOTIFICATIONS_SMTP_USER=
NOTIFICATIONS_SMTP_PASSWORD=
NOTIFICATIONS_SMTP_FROM=noreply@movies.local
NOTIFICATIONS_SMTP_USE_TLS=false

## Расписания воркеров (в секундах)
NOTIFICATIONS_SCHEDULER_INTERVAL=10
NOTIFICATIONS_PUBLISHER_INTERVAL=2
NOTIFICATIONS_RECOVERY_INTERVAL=120
NOTIFICATIONS_PUBLISHER_BATCH_SIZE=200
NOTIFICATIONS_PUBLISHER_SLEEP_BETWEEN_BATCHES=0.5

## Параметры обработки сообщений
NOTIFICATIONS_MAX_ATTEMPTS=5
NOTIFICATIONS_RETRY_TTL_MS=30000
NOTIFICATIONS_QUEUED_STUCK_TIMEOUT_SEC=300
NOTIFICATIONS_SENDING_STUCK_TIMEOUT_SEC=600

## Лимит конкурентных запросов в auth-service из scheduler
NOTIFICATIONS_AUTH_CONCURRENCY=10
NOTIFICATIONS_AUTH_TIMEOUT_SEC=5

# Сервис alerting (дипломный)
ALERTING_SENTRY_DSN=
ALERTING_STARROCKS_HOST=movies-starrocks
ALERTING_STARROCKS_PORT=9030
ALERTING_STARROCKS_USER=alert_reader
ALERTING_STARROCKS_PASSWORD=alert_reader
ALERTING_STARROCKS_DB=ugc_analytics
ALERTING_LOG_LEVEL=INFO
ALERTING_RULES_REFRESH_INTERVAL_SEC=60
ALERTING_STARROCKS_QUERY_TIMEOUT_SEC=30

# Apache Superset (BI поверх ugc_analytics)
SUPERSET_SECRET_KEY=change_me_with_openssl_rand_hex_32
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com

# Утилиты demo-tools (запуск через docker compose --profile demo run --rm movies-demo-tools <cmd>)
DEMO_KAFKA_BOOTSTRAP=movies-kafka:9092